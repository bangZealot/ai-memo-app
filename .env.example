# Supabase
# Project URL: Supabase 대시보드 > Project Settings > API > Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Service Role Key: Supabase 대시보드 > Project Settings > API > service_role (secret)
# 주의: 이 키는 RLS를 우회하는 강력한 키입니다. 반드시 서버에서만 사용하세요.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Gemini API
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your-gemini-api-key
